{
  "name": "clever-agents",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @clever/core db:generate",
    "db:migrate": "pnpm --filter @clever/core db:migrate",
    "db:studio": "pnpm --filter @clever/core db:studio",
    "dev:web": "pnpm --filter @clever/web dev",
    "dev:worker": "pnpm --filter @clever/worker dev"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.33.2"
}
