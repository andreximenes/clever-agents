# Copie para .env e preencha. NUNCA commitar o .env real.

# Senha do Postgres do projeto Supabase (Project Settings > Database).
DATABASE_PASSWORD=

# Conexão do Postgres via pooler (IPv4). Pegue em: Project Settings > Database >
# Connection pooling > Session mode. Formato:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase API (Project Settings > API). Chaves no formato novo (publishable/secret).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Espelhos para o Next.js (client-side exige prefixo NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave AES-256-GCM (32 bytes base64) para criptografar chaves de terceiros.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# Embeddings da base de conhecimento (OPCIONAL). Sem isso, agentes usam só o
# resumo dos documentos (sem busca semântica). Chave OpenAI-compatível, 1536 dims.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_BASE_URL=

# Worker
WORKER_PORT=3001
# URL pública que a Evolution usa para entregar webhooks (dev: túnel cloudflared).
WORKER_PUBLIC_URL=http://localhost:3001

# URL pública do painel (links de convite).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Envio de emails de convite (Resend). Dominio verificado no Resend.
RESEND_API_KEY=
INVITE_FROM_EMAIL=no-reply@seudominio.com

# Transcrição de áudio do WhatsApp (OPCIONAL). Sem isso, o agente pede texto.
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_MODEL=whisper-1
